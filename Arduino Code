#include <Servo.h>

// Create servo objects
Servo servo1;
Servo servo2;
Servo servo3;
Servo servo4;
Servo servo5;

// Example angles array
int angles[5] = {90, 90, 90, 90, 90}; // Initial positions

void setup() {
  // Attach servos to pins
  servo1.attach(3);
  servo2.attach(5);
  servo3.attach(6);
  servo4.attach(9);
  servo5.attach(10);
  
  // Move all servos to initial positions
  servo1.write(angles[0]);
  servo2.write(angles[1]);
  servo3.write(angles[2]);
  servo4.write(angles[3]);
  servo5.write(angles[4]);
  
  Serial.begin(9600);
  Serial.println("Servos ready!");
}

void loop() {
  // Example: increment each servo angle by 10 degrees every 2 seconds
  for(int i = 0; i < 5; i++){
    angles[i] += 10;
    if(angles[i] > 180) angles[i] = 0; // Reset if over 180
  }
  
  // Move servos
  servo1.write(angles[0]);
  servo2.write(angles[1]);
  servo3.write(angles[2]);
  servo4.write(angles[3]);
  servo5.write(angles[4]);
  
  Serial.print("Servo angles: ");
  for(int i = 0; i < 5; i++){
    Serial.print(angles[i]);
    Serial.print(" ");
  }
  Serial.println();
  
  delay(2000); // wait 2 seconds
}
